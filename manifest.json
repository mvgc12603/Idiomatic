{
  "manifest_version": 3,
  "name": "Contextual Idiom Translator",
  "version": "1.3.0",
  "description": "Suggests culturally appropriate idioms for rough cross-lingual phrases as you write.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_title": "Idiom Translator",
    "default_popup": "popup.html"
  }
}
